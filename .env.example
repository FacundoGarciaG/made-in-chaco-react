# ─── Frontend (Vite) ───────────────────────
VITE_MAPBOX_TOKEN=tu_token_mapbox
VITE_SITE_LIVE=false

# ─── Backend (Express) ─────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/db
JWT_SECRET=tu_secret_jwt
PORT=3001
NODE_ENV=development
SITE_URL=http://localhost:5173

CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu_correo@gmail.com
MAIL_PASS=tu_app_password
MAIL_FROM=noreply@madeinchaco.com

# CORS (separar múltiples orígenes con coma, solo en producción)
CORS_ORIGIN=https://madeinchaco.com.ar,https://www.madeinchaco.com.ar

# Logging (debug=0, info=1, warn=2, error=3)
LOG_LEVEL=1
